# ==== Supabase ====
# Pegue em: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# ==== IA (Claude / Anthropic) ====
# Pegue em: https://console.anthropic.com/  (Settings > API Keys)
# Se deixar em branco, o app usa dicas por regras (sem custo de IA).
ANTHROPIC_API_KEY=

# ==== (Futuro) Integracao bancaria via Pluggy - Open Finance ====
# Deixe em branco por enquanto. Preencha quando contratar a Pluggy.
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
